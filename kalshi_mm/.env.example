# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi-private-key.pem

# Quoting parameters
HALF_SPREAD_CENTS=5
CONTRACT_SIZE=2
SKEW_PER_CONTRACT=1

# Risk limits
MAX_POSITION_PER_MARKET=5
MAX_POSITION_PER_EVENT=8
MAX_TOTAL_EXPOSURE=250.0
MAX_MARKETS=20
MAX_EVENTS=10
MAX_STALENESS_SEC=600
MIN_QUOTE_SPREAD=4
LINE_MOVE_THRESHOLD=1.0
